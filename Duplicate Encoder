package kata

import (
	"strings"
)

func DuplicateEncode(word string) string {
  var slice []string
  var result string
  
  for _, val := range strings.ToLower(word) {
    count := 0
    for _, val2 := range strings.ToLower(word) {
      if string(val) == string(val2) {
        count++
      }
    }
    if count == 1 {
      slice = append(slice, "(")
    } else { slice = append(slice, ")") }
  }
  result = strings.Join(slice,"")

  return result
}
